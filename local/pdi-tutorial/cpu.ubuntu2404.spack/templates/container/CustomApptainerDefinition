# https://github.com/spack/spack/tree/develop/share/spack/templates/container

{% extends "container/singularity.def" %}
{% block build_stage %}

# A %post instruction will appear just above

# This section is executed before concatenated %post sections
%files
  custom_packages /root/

%post

  ls ~/custom_packages/spack_repo/tbouvier/patches

  . /opt/spack/share/spack/setup-env.sh
  spack repo add ~/custom_packages/spack_repo/tbouvier/patches
  spack repo list

  # OCI credentials: set APPTAINER_DOCKER_USERNAME and APPTAINER_DOCKER_PASSWORD
  # environment variables on the host before running `apptainer build`

{{ super() }}


  ##########
  # The following should be placed between the `spack install` and `spack gc` commands
  ##########
  #spack buildcache push --update-index --tag latest numpex-spack-mirror

  # Clone tutorial
  git clone -b tutorial_HPCAsia https://github.com/pdidev/tutorial.git /root/tutorial

{% endblock %}


{% block final_stage %}

%files from build
  /root/tutorial /opt/tutorial

%files
  environment_check_script.sh /opt/environment_check_script.sh

%post

{{ super() }}

  # Validation script
  chmod +x /opt/environment_check_script.sh

%environment
  export CC=/usr/local/bin/gcc
  export CXX=/usr/local/bin/g++

%runscript
  cd /opt/tutorial
  /opt/environment_check_script.sh
  exec "$@"

{% endblock %}
